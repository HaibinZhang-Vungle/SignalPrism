# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Feature Workbench round artifacts (runtime, produced by serve_round.py /
# seed_feature_set.py). The folder contract lives in its README, which IS tracked.
# global_schemas.json is the deterministic materialized catalog and IS tracked
# (so a CI staleness check can diff it against the schemas — feature_generate_spec.md).
components/Dashboard/feature_sets/*
!components/Dashboard/feature_sets/README.md
!components/Dashboard/feature_sets/global_schemas.json

